{
  "manifest_version": 3,
  "name": "NutriPlan - Food & Grocery Importer",
  "version": "1.0.0",
  "description": "Import your food delivery and grocery order history into NutriPlan for personalized nutrition planning.",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.swiggy.com/*",
    "https://www.zomato.com/*",
    "https://www.bigbasket.com/*",
    "https://blinkit.com/*",
    "https://www.zepto.co/*",
    "https://instamart.swiggy.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.swiggy.com/*"],
      "js": ["src/importers/swiggy.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.zomato.com/*"],
      "js": ["src/importers/zomato.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.bigbasket.com/*"],
      "js": ["src/importers/bigbasket.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://blinkit.com/*"],
      "js": ["src/importers/blinkit.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.zepto.co/*"],
      "js": ["src/importers/zepto.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "externally_connectable": {
    "matches": ["http://localhost:*/*", "https://*.vercel.app/*"]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
